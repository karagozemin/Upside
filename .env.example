# ─── SoSoValue (market intelligence) ─────────────────────────────
# Get key from: https://openapi.sosovalue.com
# Used for: news, ETF flows, indices, macro data
SOSOVALUE_API_KEY=

# ─── SoDEX (trading & positions) ─────────────────────────────────
# NOT the same as SoSoValue! No portal signup — wallet-based keys.
# Docs: https://sodex.com/documentation/trading-api/trading-api
#
# How to get SoDEX credentials:
# 1. Create/use an EVM wallet on SoDEX testnet
# 2. Call addAPIKey (signed by master wallet) → get key name + private key
# 3. Query GET /accounts/{address}/state → aid = SODEX_ACCOUNT_ID
#
# Leave empty for demo — orderbook is public, execution runs simulated.
SODEX_ENV=testnet
SODEX_USER_ADDRESS=
SODEX_ACCOUNT_ID=
SODEX_API_KEY_NAME=
SODEX_API_KEY_PRIVATE_KEY=

# When wallet has no open positions, desk shows a live-priced BTC showcase position
# (mark from SoDEX orderbook + risk from SoSoValue). Adjust size/leverage for display.
SODEX_SHOWCASE_BTC_SIZE=0.01
SODEX_SHOWCASE_LEVERAGE=5

# ─── Groq (AI risk memos) ────────────────────────────────────────
# Get key from: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Set to true to force demo mode even when keys are present
NEXT_PUBLIC_FORCE_DEMO=false
